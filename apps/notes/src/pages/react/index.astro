---
import { getCollection } from 'astro:content'

import { buildDomains, getDomainByKey } from '@notes/content'
import ModuleLayout from '@notes/layouts/ModuleLayout.astro'

const notes = await getCollection('notes')
const domains = buildDomains(notes)
const domain = getDomainByKey(domains, 'react')

if (!domain) {
  throw new Error('Missing React domain')
}
---

<ModuleLayout domain={domain} domains={domains} title="React | Code Atlas">
  <section class="content-card">
    <header class="note-header">
      <span class="kicker">Module Home</span>
      <h1>{domain.label}</h1>
      <p class="note-summary">{domain.description}</p>
    </header>
    <div class="note-body module-home-grid">
      {
        domain.groups.map((group) => (
          <section>
            <h2>{group.label}</h2>
            <ul class="topic-list">
              {group.topics.map((topic) => (
                <li>
                  <a href={topic.href}>{topic.title}</a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </section>
</ModuleLayout>
